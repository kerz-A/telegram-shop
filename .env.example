# === PostgreSQL ===
POSTGRES_DB=shop_db
POSTGRES_USER=shop_user
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# === Telegram Bot ===
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
BOT_WEBHOOK_HOST=bot
BOT_WEBHOOK_PORT=8081

# === Django ===
DJANGO_SECRET_KEY=change-me-to-random-50-char-string
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,admin_panel
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com

# === WebApp ===
# WEBAPP_URL: HTTPS URL where webapp is deployed. Leave empty for local development.
# The "Open Store" button in Telegram will only appear when this is set to a valid HTTPS URL.
# Example: WEBAPP_URL=https://shop.example.com
WEBAPP_URL=
VITE_API_BASE_URL=http://localhost:8000/api
